# Copy to .env.local and fill in from your Supabase project (Settings → API).
# Without these, the app runs in MOCK mode (in-memory data, no sync).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional — point The Grown-Up parser at a backend (the deployed `parse` edge
# function, or a home-lab service implementing the same contract). Unset = local
# heuristic stub (no AI). See README → "Enable real AI parsing".
VITE_PARSER_URL=
